<?xml version="1.0" encoding="UTF-8"?>

<Node nodeType="IPSecPhase2" baseType="">

    <PropertyBoolean>
        <name>enablePFS</name>
        <default>false</default>
    </PropertyBoolean>

    <PropertyString>
        <name>lifeTime</name>
        <default>28800</default>
    </PropertyString>

    <PropertyString>
	<name>ahNespMode</name>
	<default>ESPOnly</default>
	<choices>
	    <choice value="AHOnly"      name="AH Only" />
	    <choice value="ESPOnly"     name="ESP Only" />
	    <choice value="BothEHnESP"  name="AH and ESP Both" />
	</choices>
    </PropertyString>

    <PropertyString>
	<name>encapMode</name>
	<default>tunnel</default>
	<choices>
	    <choice value="tunnel"      name="Tunnel Mode" />
	    <!--choice value="transport"   name="Transport Mode" /-->
	</choices>
    </PropertyString>

    <PropertyString>
	<name>hashAlgo</name>
	<default>md5</default>
	<choices>
	    <choice value="md5"        	name="HMAC-MD5" />
	    <choice value="sha1"       	name="HMAC-SHA1" />
	</choices>
    </PropertyString>

    <PropertyString>
	<name>pfsGroup</name>
	<default>dh2</default>
	<choices>
	    <choice value="dh1"       	name="DH-1" />
	    <choice value="dh2"       	name="DH-2" />
	    <choice value="dh5"       	name="DH-5" />
	    <choice value="dh14"      	name="DH-14" />
	    <choice value="dh15"      	name="DH-15" />
	    <choice value="dh16"      	name="DH-16" />
	</choices>
    </PropertyString>

    <PropertyString>
	<name>encAlgo</name>
	<default>3des</default>
	<choices>
	    <choice value="null"      	name="NULL" />
	    <choice value="des"      	name="DES" />
	    <choice value="3des"     	name="3-DES" />
	    <choice value="aes128"      name="AES-128" />
	    <choice value="aes192"      name="AES-192" />
	    <choice value="aes256"      name="AES-256" />
	</choices>
    </PropertyString>

</Node>
