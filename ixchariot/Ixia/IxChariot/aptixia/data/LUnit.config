<?xml version="1.0" encoding="utf-8"?> 
<!-- LUnit.config -->
<configuration>
<lunit>
 <logging>
 <set key="always_send_to_console" value="true" />
 </logging>
 <defaults>
  <set key="ixia_chassis" value="192.168.4.246" />
  <set key="ixia_chassis_no" value="0" />
  <set key="ixia_card_no" value="2" />
  <set key="ixia_port_no" value="8" />

  <set key="ixia_chassisb" value="192.168.4.246" />
  <set key="ixia_chassisb_no" value="0" />
  <set key="ixia_cardb_no" value="2" />
  <set key="ixia_portb_no" value="7" />

  <set key="ixia_port_addr_format" value="10.{0}.{1}.{2}" />

  <set key="iteration_multiplier" value="10" />
 </defaults>
</lunit>
</configuration>
