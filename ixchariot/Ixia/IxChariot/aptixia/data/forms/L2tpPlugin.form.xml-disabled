    <EventSources type="System.Collections.ArrayList">
        <Capacity type="System.Int32">32</Capacity>
        <SyncRoot type="System.Object" />
        <element type="aptixia.sm.EventCSSource" uuid="cb544f19-007b-40ae-97d0-4c74e50aa0bc">
            <Control type="aptixia.sm.DynamicGridControl" ref="b3f7d35b-9ae4-47ca-ad59-bc034b0c67d5" />
            <EventName type="System.String">InitCellEditor</EventName>
            <CSSource type="System.String">if (i_arg1.RowType != typeof(L2tpTunDestIpRange)) {
    return; // don't see why this is needed but the ipv4v6range example does this..
}
if (i_arg1.FieldName  != "sourceIpRange" ) {
   return; // field does not need a special source, return
}
System.Console.WriteLine("i_arg1 = {0} fieldName = {0}", i_arg1, i_arg1.FieldName.ToString());
// note: m_obect is the l2tp plugin object. not the tunnel list object

if (i_arg1.FieldName == "sourceIpRange") {

    if (i_arg1.ColumnEditor == null)  { System.Console.WriteLine("null for col editor"); return;}
    //System.Console.WriteLine("got col editor");

    IpV4V6Plugin plugin=(IpV4V6Plugin)m_object.GetAncestor(typeof(IpV4V6Plugin));
    //IpV4V6Plugin plugin=null;
    if (plugin == null) {
       System.Console.WriteLine("can't find Ipv4v6 parent plugin ???");
       return;
    }

    DevExpress.XtraEditors.Repository.RepositoryItemLookUpEdit edit =
        (DevExpress.XtraEditors.Repository.RepositoryItemLookUpEdit)i_arg1.ColumnEditor;
    edit.DisplayMember = "name";
    edit.ValueMember   = "$$OBJECT$$";

    edit.DataSource=new DynamicDataList(plugin.rangeList);
    edit.Columns.Clear();
    edit.Columns.Add(new DevExpress.XtraEditors.Controls.LookUpColumnInfo("name"));
   // edit.Columns.Add(new DevExpress.XtraEditors.Controls.LookUpColumnInfo("$$OBJECT$$"));

    return;
}




</CSSource>
        </element>
        <element type="aptixia.sm.EventCSSource" uuid="29dedfbf-2edb-4d09-8dd6-1c0b02d9db21">
            <Control type="aptixia.sm.DynamicGridControl" ref="b3f7d35b-9ae4-47ca-ad59-bc034b0c67d5" />
            <EventName type="System.String">LookupAddNewValue</EventName>
            <CSSource type="System.String">// LookupAddNewValue handler

if (!i_arg1.ColumnType.Equals(typeof(aptixia.clcs.MacRange))) {
    return;
}
if (i_arg1.Data.ToString().Length == 0) {
    return;
}

L2tpTunDestIpRange tundst_range = (L2tpTunDestIpRange)m_form.w_L2tpTunDestIpRange_Grid.SelectedRow;
if (tundst_range == null) {
    return;
}

if (i_arg1.ColumnType.Equals(typeof(aptixia.clcs.IpV4V6Range))) {
    IpV4V6Plugin ipPlugin = null; //GetAncestor(typeof(EthernetPlugin));
    if (ipPlugin== null) {
        return; // ancestor is not present , bail
    }
   IpV4V6Range srcip_range=IpV4V6Range._Create(m_object._Context); // create new item
   srcip_range.name = i_arg1.Data.ToString();

   tundst_range.sourceIpRange=srcip_range; // attach to this tundst_range decord
   ipPlugin.rangeList.Add(srcip_range); // add  to ancestori plugin
   ipPlugin._Context.SyncAll();
   tundst_range._Context.SyncAll();
}

return; //done
</CSSource>
        </element>
        <element type="aptixia.sm.EventCSSource" uuid="96a37832-799f-4c92-ba66-76a6d2d96d7d">
            <Control type="DevExpress.XtraEditors.TextEdit" ref="35d2b3e6-a194-49d7-90cd-6ffbf7d3b551" />
            <EventName type="System.String">Validating</EventName>
            <CSSource type="System.String">string e=Schema.GetValidationError("L2tp.localHostName",
  m_form.w_localHostName.Text);

m_root.ErrorProvider.SetError(m_form.w_localHostName, e);
i_arg1.Cancel=(e.Length!=0);</CSSource>
        </element>
        <element type="aptixia.sm.EventCSSource" uuid="29bb3a90-88ba-43a7-bf13-f09ecbd94288">
            <Control type="DevExpress.XtraEditors.TextEdit" ref="77cf52ed-82fa-41d4-b00b-0cbe3c56154d" />
            <EventName type="System.String">Validating</EventName>
            <CSSource type="System.String">// Validating Evt Handler using schema validator, TextBox
string e=Schema.GetValidationError("L2tp.secret",m_form.w_secret.Text);

m_root.ErrorProvider.SetError(m_form.w_secret, e);
i_arg1.Cancel=(e.Length!=0);</CSSource>
        </element>
        <element type="aptixia.sm.EventCSSource" uuid="5ca9e305-538e-4c76-bdbc-694d9fad3e15">
            <Control type="DevExpress.XtraEditors.TextEdit" ref="13c52463-4b55-493b-8330-de264ba12283" />
            <EventName type="System.String">Validating</EventName>
            <CSSource type="System.String">// Validating Evt Handler using schema validator, TextBox
string e=Schema.GetValidationError("L2tp.peerHostName",
  m_form.w_peerHostName.Text);

m_root.ErrorProvider.SetError(m_form.w_peerHostName, e);
