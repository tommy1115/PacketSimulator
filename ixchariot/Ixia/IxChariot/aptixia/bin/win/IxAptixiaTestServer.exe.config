<?xml version="1.0" encoding="UTF-8" ?>
<configuration>
	<configSections>
	    <section name="DbSettings" type=
	       "System.Configuration.NameValueSectionHandler,System"/>
	</configSections>
	<DbSettings>		
		<add key="xDb_SqlClient" value="Integrated Security=SSPI;Persist Security Info=False;Initial Catalog=aptixiaDb_2_B;Data Source=(local)\AptixiaDataStore;Pooling=true;Min Pool Size=5;Max Pool Size=100;"/>
		<add key="xDb_OleDb" value="Provider=SQLOLEDB.1;Persist Security Info=False;Initial Catalog=aptixiaDb_2_B;Data Source=(local)\AptixiaDataStore;Pooling=true;Min Pool Size=5;Max Pool Size=100;User Id=userTestServer;Password=8x/g7P12G9MhLbHOsU7Z4+SzvHyOeOjs3q2KqARqOMQ=;"/>
		<add key="xDb_Odbc" value="Driver={SQL Server};Server=(local)\AptixiaDataStore;Database=aptixiaDb_2_B;Pooling=true;Min Pool Size=5;Max Pool Size=100;Uid=userTestServer;Pwd=8x/g7P12G9MhLbHOsU7Z4+SzvHyOeOjs3q2KqARqOMQ=;"/>
		<add key="xDb_Reporter" value="Driver={SQL Server};Server=(local)\AptixiaDataStore;Database=aptixiaDb_2_B;Pooling=true;Min Pool Size=5;Max Pool Size=100;Uid=userReporter;Pwd=OfJQfZk9f9FXyeMct4YuLc8CmNTAd9iDHQ82scrfYg8="/>
		<add key="xDb_DataProvider" value="xDb_SqlClient"/>	
		<add key="Demo_overRideTestResultId" value="0"/>
		<add key="Demo_beginTimeStamp" value="0"/>
		<add key="Demo_endTimeStamp" value="0"/>
	</DbSettings>   
    <system.diagnostics>
        <switches>
            <!-- value property:  0=off, 1-5 method calls, 6-10 + message content, > 10 SSL encrypted messages -->
            <add name="ORBDebugLevel" value="0" />

            <!-- value property:  Use real Database for DataStore access? 0=no, 1=yes -->
            <add name="UseDB" value="1" />
        </switches>
        <trace autoflush="false" indentsize="4" />
    </system.diagnostics>
</configuration>
